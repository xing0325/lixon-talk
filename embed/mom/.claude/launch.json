{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python http.server (static)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "--bind", "127.0.0.1"],
      "port": 8000
    },
    {
      "name": "npx serve (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "--listen", "3000", "."],
      "port": 3000
    }
  ]
}
